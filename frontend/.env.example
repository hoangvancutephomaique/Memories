# Unlock viewing messages (baked into the Pages build — use only for privacy-by-obscurity).
VITE_OWNER_USER=your_username
VITE_OWNER_PASS=your_password

# URL of your deployed Spring Boot backend, e.g. https://guestbook-api.onrender.com
# Leave blank for local dev (Vite proxies to localhost:8080 automatically)
VITE_API_URL=

# Facebook Login — numeric App ID from Meta Developer Console (same app the backend verifies).
VITE_FACEBOOK_APP_ID=

# Delete password is NOT here — set GUESTBOOK_DELETE_SECRET on Render (server only).
# Backend also needs FACEBOOK_APP_ID and FACEBOOK_APP_SECRET on the server to verify tokens.
